<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_incident.xml
  Edge-to-Edge layout: bg_static_shield gradient flows behind status bar
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/incidentRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_static_shield">

    <!-- Toolbar: transparent so gradient shows through -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/incidentToolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"
        app:titleTextColor="#00C8FF"
        app:title="INCIDENT REPORT"
        app:navigationIcon="?attr/homeAsUpIndicator" />

    <!-- TabLayout: semi-transparent so gradient peeks through -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/incidentTabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#CC101828"
        app:tabSelectedTextColor="#00C8FF"
        app:tabTextColor="#8892A4"
        app:tabIndicatorColor="#00C8FF"
        app:tabIndicatorHeight="3dp"
        app:tabRippleColor="#1A2744"
        app:tabMode="fixed"
        app:tabGravity="fill" />

    <!-- ViewPager2: fills remaining space, holds Timeline + DNA Report fragments -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/incidentViewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@android:color/transparent" />

</LinearLayout>
