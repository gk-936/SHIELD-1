<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_static_shield">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbarSettings"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Settings"
            app:titleCentered="true"
            app:titleTextColor="@color/text_primary" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Actions Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Actions"
                android:textColor="@color/primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <!-- DEMO MODE — top of Actions, impossible to miss -->
            <Button
                android:id="@+id/btnDemoMode"
                style="@style/Widget.Shield.Button.Frosted"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:text="▶  LIVE DEMO MODE"
                android:textSize="17sp"
                android:layout_marginBottom="16dp"
                app:backgroundTint="@null"/>

            <Button
                android:id="@+id/btnClearHoneyfilesSettings"
                style="@style/Widget.Shield.Button.Frosted"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Clear Honeyfiles"
                android:textSize="16sp"
                android:textColor="#EF4444"
                android:layout_marginBottom="12dp"
                app:backgroundTint="@null"/>

            <Button
                android:id="@+id/btnTestSuiteSettings"
                style="@style/Widget.Shield.Button.Frosted"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Test Suite"
                android:textSize="16sp"
                android:textColor="#FF6F00"
                android:layout_marginBottom="12dp"
                app:backgroundTint="@null"/>

            <Button
                android:id="@+id/btnUserGuide"
                style="@style/Widget.Shield.Button.Frosted"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="User Guide"
                android:textSize="16sp"
                android:layout_marginBottom="12dp"
                app:backgroundTint="@null"/>

            <Button
                android:id="@+id/btnManageWhitelist"
                style="@style/Widget.Shield.Button.Frosted"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Manage Whitelist"
                android:textSize="16sp"
                android:textColor="#00E676"
                android:layout_marginBottom="12dp"
                app:backgroundTint="@null"/>

            <Button
                android:id="@+id/btnAccessibility"
                style="@style/Widget.Shield.Button.Frosted"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="♿  Accessibility Service"
                android:textSize="16sp"
                android:textColor="#60A5FA"
                android:layout_marginBottom="24dp"
                app:backgroundTint="@null"/>

            <!-- Permissions Section (Collapsible) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Permissions"
                android:textColor="@color/primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg_premium"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvPermissionCount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Total Permissions: 0 (Tap to expand)"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground"
                    android:padding="8dp" />

                <ScrollView
                    android:id="@+id/permissionListContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxHeight="300dp"
                    android:visibility="gone"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:id="@+id/tvPermissionList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Loading permissions..."
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:fontFamily="monospace" />
                </ScrollView>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
