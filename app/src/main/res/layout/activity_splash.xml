<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_static_shield">

    <!-- ── Logo row, centred on screen ── -->
    <LinearLayout
        android:id="@+id/logoBlock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- ── Shield App Logo column ── -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@mipmap/ic_launcher_round"
                android:contentDescription="Shield Logo"
                android:alpha="0.95"/>

            <!-- Animated label replacing the old "SHIELD" TextView -->
            <com.dearmoon.shield.ui.AnimatedLetterTextView
                android:id="@+id/animatedShieldLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:alt_text="SHIELD"
                app:alt_letterDelay="80"
                app:alt_textSize="14sp"
                app:alt_textColor="#00C8FF"
                app:alt_underlineGradientStart="#00C8FF"
                app:alt_underlineGradientEnd="#7B2FBE"
                app:alt_underlineHeight="2dp"
                app:alt_underlineOffset="3dp"/>

        </LinearLayout>

        <!-- ── Cyan glowing divider ── -->
        <View
            android:layout_width="1.5dp"
            android:layout_height="80dp"
            android:layout_marginHorizontal="32dp"
            android:background="#6600E5FF"/>

        <!-- ── DSCI Logo column ── -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/ic_dsci_logo"
                android:contentDescription="DSCI Logo"
                android:alpha="0.95"/>

            <!-- Animated label replacing the old "DSCI" TextView -->
            <com.dearmoon.shield.ui.AnimatedLetterTextView
                android:id="@+id/animatedDsciLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:alt_text="DSCI"
                app:alt_letterDelay="80"
                app:alt_textSize="14sp"
                app:alt_textColor="#8892A4"
                app:alt_underlineGradientStart="#8892A4"
                app:alt_underlineGradientEnd="#444F60"
                app:alt_underlineHeight="2dp"
                app:alt_underlineOffset="3dp"/>

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
