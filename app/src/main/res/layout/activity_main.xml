<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_static_shield"
    tools:context=".MainActivity">

    <!-- DSCI Logo - Top Right Corner -->
    <ImageView
        android:id="@+id/ivDsciLogo"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:src="@drawable/ic_dsci_logo"
        android:contentDescription="DSCI Logo"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:elevation="4dp"
        android:alpha="0.9"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- SHIELD Title with Data Leak Effect -->
    <com.dearmoon.shield.ui.DataLeakTextView
        android:id="@+id/appTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SHIELD"
        android:textColor="@color/text_primary"
        android:textSize="24sp"
        android:letterSpacing="0.2"
        android:textStyle="bold"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Infection Countdown Timer -->
    <LinearLayout
        android:id="@+id/timerContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#00385a"
        android:padding="12dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠️ SYSTEM COMPROMISE IN PROGRESS"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvInfectionTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Time to total infection: 00:00"
            android:textColor="#FFFFFF"
            android:layout_gravity="center"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Status Header with Glitch Effect -->
    <com.dearmoon.shield.ui.GlitchTextView
        android:id="@+id/tvProtectionStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Protection Inactive"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/appTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Security Semicircular Gauge -->
    <com.dearmoon.shield.ui.SecurityGaugeView
        android:id="@+id/gaugeView"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/tvProtectionStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <!-- Unified Protection Button (Merged Root + Non-Root) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintBottom_toTopOf="@id/fluidMenu"
        app:layout_constraintTop_toBottomOf="@id/gaugeView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:padding="32dp">

        <!-- Unified Protection Toggle (Root + Non-Root) -->
        <Button
            android:id="@+id/btnUnifiedProtection"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:text="Start Protection"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:background="@drawable/bg_glass_button_inactive"
            app:backgroundTint="@null"
            android:layout_marginBottom="8dp" />

    </LinearLayout>





    <!-- ── Floating Fluid Menu — bottom centre, above all content ── -->
    <com.dearmoon.shield.ui.FluidMenuView
        android:id="@+id/fluidMenu"
        android:layout_width="match_parent"
        android:layout_height="88dp"
        android:layout_marginBottom="16dp"
        android:elevation="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ── Security Ripple overlay — must be LAST child so it renders on top ── -->
    <com.dearmoon.shield.ui.SecurityRippleView
        android:id="@+id/securityRipple"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clickable="false"
        android:focusable="false"
        android:elevation="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
