<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_static_shield"
    tools:context=".MainActivity">

    <!-- DSCI Logo - Top Right Corner -->
    <ImageView
        android:id="@+id/ivDsciLogo"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:src="@drawable/ic_dsci_logo"
        android:contentDescription="DSCI Logo"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:elevation="4dp"
        android:alpha="0.9"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- SHIELD Title with Data Leak Effect -->
    <com.dearmoon.shield.ui.DataLeakTextView
        android:id="@+id/appTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SHIELD"
        android:textColor="@color/text_primary"
        android:textSize="24sp"
        android:letterSpacing="0.2"
        android:textStyle="bold"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Infection Countdown Timer -->
    <LinearLayout
        android:id="@+id/timerContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#00385a"
        android:padding="12dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠️ SYSTEM COMPROMISE IN PROGRESS"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvInfectionTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Time to total infection: 00:00"
            android:textColor="#FFFFFF"
            android:layout_gravity="center"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Status Header with Glitch Effect -->
    <com.dearmoon.shield.ui.GlitchTextView
        android:id="@+id/tvProtectionStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Protection Inactive"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/appTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Security Stats Card — 2-column premium design -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/statsCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="20dp"
        app:cardBackgroundColor="#00000000"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="#1A4488AA"
        app:layout_constraintTop_toBottomOf="@id/tvProtectionStatus">

        <!-- Frosted glass inner background -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_stats_card_frosted">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="20dp"
                android:paddingHorizontal="8dp">

                <!-- ═══ COLUMN 1: Attacks Found ════════════════════════════ -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingHorizontal="12dp">

                    <!-- Big number -->
                    <TextView
                        android:id="@+id/tvSafeFiles"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#00C8FF"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-condensed"
                        android:letterSpacing="-0.02"
                        android:layout_gravity="center" />

                    <!-- Glowing underline accent -->
                    <View
                        android:layout_width="40dp"
                        android:layout_height="2dp"
                        android:background="@drawable/bg_stat_accent_cyan"
                        android:layout_gravity="center"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="8dp" />

                    <!-- Label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Attacks Found"
                        android:textColor="#66A0C0"
                        android:textSize="11sp"
                        android:letterSpacing="0.08"
                        android:textAllCaps="true"
                        android:fontFamily="sans-serif-medium"
                        android:layout_gravity="center" />

                </LinearLayout>

                <!-- Vertical divider -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="72dp"
                    android:layout_gravity="center_vertical"
                    android:background="@drawable/bg_stat_divider" />

                <!-- ═══ COLUMN 2: Files Scanned ═════════════════════════════ -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingHorizontal="12dp">

                    <!-- Big number -->
                    <TextView
                        android:id="@+id/tvTotalFiles"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#52B788"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-condensed"
                        android:letterSpacing="-0.02"
                        android:layout_gravity="center" />

                    <!-- Glowing underline accent -->
                    <View
                        android:layout_width="40dp"
                        android:layout_height="2dp"
                        android:background="@drawable/bg_stat_accent_green"
                        android:layout_gravity="center"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="8dp" />

                    <!-- Label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Files Scanned"
                        android:textColor="#4A9060"
                        android:textSize="11sp"
                        android:letterSpacing="0.08"
                        android:textAllCaps="true"
                        android:fontFamily="sans-serif-medium"
                        android:layout_gravity="center" />

                </LinearLayout>

            </LinearLayout>

        </FrameLayout>

        <!-- tvInfectedFiles kept invisible for Java backward compatibility -->
        <TextView
            android:id="@+id/tvInfectedFiles"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            android:text="0" />

    </com.google.android.material.card.MaterialCardView>


    <!-- Main Mode Buttons -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintBottom_toTopOf="@id/fluidMenu"
        app:layout_constraintTop_toBottomOf="@id/statsCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:padding="32dp">

        <!-- Mode A (Root - Inactive) -->
        <Button
            android:id="@+id/btnModeA"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:text="Root"
            android:textSize="18sp"
            android:textColor="@color/text_muted"
            android:background="@drawable/bg_glass_button_inactive"
            app:backgroundTint="@null"
            android:layout_marginBottom="16dp" />

        <!-- Mode B (Non-Root Toggle) -->
        <Button
            android:id="@+id/btnModeB"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:text="Non-Root"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:background="@drawable/bg_glass_button_inactive"
            app:backgroundTint="@null"
            android:layout_marginBottom="8dp" />

    </LinearLayout>





    <!-- ── Floating Fluid Menu — bottom centre, above all content ── -->
    <com.dearmoon.shield.ui.FluidMenuView
        android:id="@+id/fluidMenu"
        android:layout_width="match_parent"
        android:layout_height="88dp"
        android:layout_marginBottom="16dp"
        android:elevation="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ── Security Ripple overlay — must be LAST child so it renders on top ── -->
    <com.dearmoon.shield.ui.SecurityRippleView
        android:id="@+id/securityRipple"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clickable="false"
        android:focusable="false"
        android:elevation="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
