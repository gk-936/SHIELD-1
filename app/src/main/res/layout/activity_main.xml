<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_static_shield"
    tools:context=".MainActivity">

    <!-- DSCI Logo - Top Right Corner -->
    <ImageView
        android:id="@+id/ivDsciLogo"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:src="@drawable/ic_dsci_logo"
        android:contentDescription="DSCI Logo"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:elevation="4dp"
        android:alpha="0.9"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- SHIELD Title with Data Leak Effect -->
    <com.dearmoon.shield.ui.DataLeakTextView
        android:id="@+id/appTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SHIELD"
        android:textColor="@color/text_primary"
        android:textSize="24sp"
        android:letterSpacing="0.2"
        android:textStyle="bold"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Infection Countdown Timer -->
    <LinearLayout
        android:id="@+id/timerContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#EF4444"
        android:padding="12dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠️ SYSTEM COMPROMISE IN PROGRESS"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvInfectionTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Time to total infection: 00:00"
            android:textColor="#FFFFFF"
            android:layout_gravity="center"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Status Header with Glitch Effect -->
    <com.dearmoon.shield.ui.GlitchTextView
        android:id="@+id/tvProtectionStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Protection Inactive"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/appTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Security Stats Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/statsCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="#1A1A1A"
        app:cardCornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvProtectionStatus">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/tvSafeFiles"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#10B981"
                    android:textSize="20sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Attacks Blocked"
                    android:textColor="#888888"
                    android:textSize="12sp" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#333333" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/tvInfectedFiles"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#EF4444"
                    android:textSize="20sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Threats Found"
                    android:textColor="#888888"
                    android:textSize="12sp" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#333333" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/tvTotalFiles"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#3B82F6"
                    android:textSize="20sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Files Scanned"
                    android:textColor="#888888"
                    android:textSize="12sp" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Main Mode Buttons -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintBottom_toTopOf="@id/bottomNavContainer"
        app:layout_constraintTop_toBottomOf="@id/statsCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:padding="32dp">

        <!-- Mode A (Root - Inactive) -->
        <Button
            android:id="@+id/btnModeA"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:text="Root"
            android:textSize="18sp"
            android:textColor="@color/text_muted"
            android:background="@drawable/bg_glass_button_inactive"
            app:backgroundTint="@null"
            android:layout_marginBottom="16dp" />

        <!-- Mode B (Non-Root Toggle) -->
        <Button
            android:id="@+id/btnModeB"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:text="Non-Root"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:background="@drawable/bg_glass_button_inactive"
            app:backgroundTint="@null"
            android:layout_marginBottom="20dp" />

        <!-- Live Demo Button — always visible on home screen -->
        <Button
            android:id="@+id/btnLiveDemo"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="▶  LIVE ATTACK DEMO"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#9D00FF"
            android:letterSpacing="0.05" />

    </LinearLayout>

    <!-- Bottom Navigation Bar (Glassmorphism Oval) -->
    <LinearLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/bg_glass_oval"
        android:layout_margin="16dp"
        android:paddingHorizontal="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Left: Locker Guard & View Logs -->
        <ImageButton
            android:id="@+id/btnNavLocker"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_gravity="center_vertical"
            android:padding="12dp"
            android:src="@android:drawable/ic_lock_idle_lock"
            android:background="@drawable/bg_glass_circle_btn"
            android:contentDescription="Locker Guard"
            app:tint="@color/text_primary" />

        <ImageButton
            android:id="@+id/btnNavLogs"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_gravity="center_vertical"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_agenda"
            android:background="@drawable/bg_glass_circle_btn"
            android:contentDescription="View Logs"
            app:tint="@color/text_primary" />

        <!-- Center: File Monitor -->
        <ImageButton
            android:id="@+id/btnNavFile"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_gravity="center_vertical"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_save"
            android:background="@drawable/bg_glass_circle_btn"
            android:contentDescription="File Monitor"
            app:tint="@color/text_primary" />

        <!-- Right: Snapshot & Settings -->
        <ImageButton
            android:id="@+id/btnNavSnapshot"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_gravity="center_vertical"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="@drawable/bg_glass_circle_btn"
            android:contentDescription="Snapshot"
            app:tint="@color/text_primary" />

        <ImageButton
            android:id="@+id/btnNavSettings"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_gravity="center_vertical"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_preferences"
            android:background="@drawable/bg_glass_circle_btn"
            android:contentDescription="Settings"
            app:tint="@color/primary" />

    </LinearLayout>


    <!-- ════════════════ INTERACTIVE GUIDE CONTAINER ════════════════ -->
    <!-- Guaranteed top-level Z-ordering. Shows/hides the entire guide flow safely -->
    <FrameLayout
        android:id="@+id/guideOverlayContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:elevation="60dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 1. Spotlight Overlay (Background layer of guide)
             Is clickable to absorb stray screen touches, preventing interaction with
             the app buttons underneath. -->
        <com.dearmoon.shield.ui.GuideSpotlightView
            android:id="@+id/guideSpotlightView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="true"
            android:focusable="true" />

        <!-- 2. Dynamic Island pill with liquid water fill -->
        <FrameLayout
            android:id="@+id/dynamicIslandContainer"
            android:layout_width="160dp"
            android:layout_height="30dp"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="42dp"
            android:clipToOutline="true"
            android:background="@drawable/bg_dynamic_island_pill">

            <!-- Water fill animation (left → right) -->
            <com.dearmoon.shield.ui.WaterFillView
                android:id="@+id/guideWaterFill"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- Step label overlaid on the fill -->
            <TextView
                android:id="@+id/tvIslandStep"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.2"
                android:shadowColor="#000000"
                android:shadowDx="0"
                android:shadowDy="0"
                android:shadowRadius="4"
                android:text="1 / 7" />
        </FrameLayout>

        <!-- 3. Tooltip card — sits just below the pill -->
        <androidx.cardview.widget.CardView
            android:id="@+id/guideTooltipCard"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="84dp"
            app:cardBackgroundColor="#1C1C2E"
            app:cardCornerRadius="16dp"
            app:cardElevation="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/guideStepTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#9575CD"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:shadowColor="#9575CD"
                    android:shadowDx="0"
                    android:shadowDy="0"
                    android:shadowRadius="10"
                    android:layout_marginBottom="6dp"
                    android:text="Root Mode" />

                <TextView
                    android:id="@+id/guideTextMsg"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#CCCCCC"
                    android:textSize="13sp"
                    android:lineSpacingExtra="3dp"
                    android:text="Description" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 4. Finale dark overlay (Topmost background) -->
        <View
            android:id="@+id/guideFinaleOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#EE000000"
            android:visibility="gone" />

        <!-- 5a. BinaryConvergeView — full-screen data-stream compilation finale -->
        <com.dearmoon.shield.ui.BinaryConvergeView
            android:id="@+id/binaryConvergeView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <!-- 5b. Hidden GlitchTextView kept so MainActivity field ref compiles -->
        <com.dearmoon.shield.ui.GlitchTextView
            android:id="@+id/tvLetsSecure"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="SYSTEM ARMED"
            android:textColor="#00f3ff"
            android:textSize="36sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:fontFamily="monospace"
            android:visibility="gone" />



        <!-- 6. Next / Finish button — Guaranteed Topmost interactive element -->
        <!-- Placed bottom | end, well above gesture boundary -->
        <Button
            android:id="@+id/btnGuideNext"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="112dp"
            android:text="Next →"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:paddingHorizontal="32dp"
            app:backgroundTint="#9D00FF" />

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>


