<?xml version="1.0" encoding="utf-8"?>
<!-- Outer container — the transparent part (top 20% peeks through) -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/outerRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <!--
        The 80% sheet — positioned at the BOTTOM of the screen.
        Rounded top corners. Teal gradient background drawn by OrbAnimationView.
    -->
    <FrameLayout
        android:id="@+id/rootView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_gravity="bottom"
        android:clipToOutline="true"
        android:background="@drawable/bg_mode_confirm_sheet">

        <!-- Full-area orb animation — draws the teal gradient + cone rings + orb -->
        <com.dearmoon.shield.ui.OrbAnimationView
            android:id="@+id/orbView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Drag handle pill — identical to reference image chip at top -->
        <TextView
            android:id="@+id/modeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="20dp"
            android:text="ACTIVATING ROOT MODE"
            android:textColor="#BBFFFFFF"
            android:textSize="11sp"
            android:letterSpacing="0.20"
            android:textAllCaps="true"
            android:fontFamily="sans-serif-medium"
            android:paddingHorizontal="18dp"
            android:paddingVertical="7dp"
            android:background="@drawable/bg_mode_label_chip" />

        <!--
            Main headline — matches reference "Breathe in, we have got you":
            - Large text, light weight, centred
            - Soft light teal color to blend with teal background
        -->
        <TextView
            android:id="@+id/messageText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="72dp"
            android:layout_marginHorizontal="32dp"
            android:text="Breathe in,\nwe have covered you."
            android:textColor="#BEE0E0"
            android:textSize="30sp"
            android:fontFamily="sans-serif-light"
            android:gravity="center"
            android:lineSpacingMultiplier="1.25" />

        <!-- Bottom: tap anywhere hint — same translucent grey as reference -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="36dp"
            android:text="Tap anywhere to continue"
            android:textColor="#448899AA"
            android:textSize="12sp"
            android:letterSpacing="0.08"
            android:fontFamily="sans-serif" />

    </FrameLayout>

</FrameLayout>
