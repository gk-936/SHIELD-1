<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_static_shield"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Header bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp">

            <Button
                android:id="@+id/btnRootInfoBack"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="← Back"
                android:textColor="#CCCCCC"
                android:textSize="13sp"
                android:backgroundTint="#222222"
                android:paddingHorizontal="16dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Root Mode"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:letterSpacing="0.1" />

            <!-- Spacer to balance back button -->
            <View
                android:layout_width="72dp"
                android:layout_height="1dp" />
        </LinearLayout>

        <!-- Lock icon -->
        <android.widget.ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@android:drawable/ic_lock_lock"
            android:layout_marginBottom="16dp"
            app:tint="#9D00FF" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kernel-Level Protection"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <!-- Subtitle pill -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="  COMING IN v2.0  "
            android:textColor="#9D00FF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:background="#1A0033"
            android:paddingVertical="4dp"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="32dp" />

        <!-- What root mode adds -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#0D0D1A"
            app:cardCornerRadius="14dp"
            app:strokeColor="#9D00FF"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WHAT ROOT MODE ADDS"
                    android:textColor="#9D00FF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="16dp" />

                <!-- Feature rows -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="14dp">
                    <TextView android:layout_width="28dp" android:layout_height="wrap_content"
                        android:text="⚡" android:textSize="18sp" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:paddingStart="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Kernel Syscall Interception"
                            android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Hook open(), write(), rename() at the kernel level — catch ransomware before it touches the filesystem."
                            android:textColor="#888888" android:textSize="12sp" android:lineSpacingExtra="2dp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="14dp">
                    <TextView android:layout_width="28dp" android:layout_height="wrap_content"
                        android:text="🔬" android:textSize="18sp" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:paddingStart="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Deep Process Inspection"
                            android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Inspect process memory maps and loaded libraries to identify injected ransomware modules."
                            android:textColor="#888888" android:textSize="12sp" android:lineSpacingExtra="2dp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="14dp">
                    <TextView android:layout_width="28dp" android:layout_height="wrap_content"
                        android:text="🧠" android:textSize="18sp" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:paddingStart="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Cryptographic Key Extraction"
                            android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="With root access, extract ransomware encryption keys from process memory before files are locked."
                            android:textColor="#888888" android:textSize="12sp" android:lineSpacingExtra="2dp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="28dp" android:layout_height="wrap_content"
                        android:text="🛑" android:textSize="18sp" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:paddingStart="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Process Kill Before First Write"
                            android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Terminate a ransomware process the instant its first suspicious syscall is detected — zero files encrypted."
                            android:textColor="#888888" android:textSize="12sp" android:lineSpacingExtra="2dp" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Why it needs root -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#111111"
            app:cardCornerRadius="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WHY ROOT IS REQUIRED"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Android's security model prevents user-space apps from accessing kernel interfaces like inotify at the syscall level or reading /proc/pid/maps of other processes. Root access grants the necessary privileges to hook these interfaces safely.\n\nMode B (Non-Root) is already running and protects 99% of Android devices without these privileges."
                    android:textColor="#AAAAAA"
                    android:textSize="13sp"
                    android:lineSpacingExtra="4dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Current coverage reminder -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            app:cardBackgroundColor="#0A1A0A"
            app:cardCornerRadius="14dp"
            app:strokeColor="#10B981"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✅"
                    android:textSize="22sp"
                    android:layout_marginEnd="12dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mode B is active and protecting you now"
                        android:textColor="#10B981"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Entropy + KL + SPRT detection · VPN network guard · AES-256 snapshot recovery"
                        android:textColor="#5A8A6A"
                        android:textSize="12sp"
                        android:lineSpacingExtra="2dp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
