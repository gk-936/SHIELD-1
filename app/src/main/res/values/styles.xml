<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
      ════════════════════════════════════════════════
      SHIELD Frosted-Glass Button Styles
      ════════════════════════════════════════════════
      Applied globally via Theme.SHIELD buttonStyle override
      so ALL Button widgets in the app inherit this look
      without needing per-button style= attributes.

      Key rules:
        • android:stateListAnimator="@null"  — removes the default
          Material elevation pulse animation (wrong on flat buttons)
        • android:elevation="0dp"           — no shadow, flat appearance
        • app:backgroundTint="@null"        — must be set in XML on any
          MaterialButton to let android:background drive the drawable
    -->

    <!-- ── Primary pill button (text + icon actions) ──────────────────────── -->
    <!-- Renamed internally but keeping the style name "Frosted" so we don't break all XMLs -->
    <style name="Widget.Shield.Button.Frosted" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_button_neumorphic</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingHorizontal">32dp</item>
        <item name="android:paddingVertical">16dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:elevation">0dp</item> <!-- Handled by custom drawable inset -->
        <item name="android:letterSpacing">0.02</item>
    </style>

    <!-- ── Circle icon-only button (e.g. nav bar items) ─────────────────── -->
    <style name="Widget.Shield.Button.FrostedCircle" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_button_neumorphic_circle</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:elevation">0dp</item>
        <item name="android:minWidth">56dp</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:padding">0dp</item>
    </style>

    <!-- ── Borderless / text-only action buttons ─────────────────────────── -->
    <style name="Widget.Shield.Button.Text" parent="Widget.AppCompat.Button.Borderless">
        <item name="android:textColor">#99FFFFFF</item>
        <item name="android:textSize">14sp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:elevation">0dp</item>
    </style>

</resources>
