<?xml version="1.0" encoding="utf-8"?>
<!--
    Inactive button — dark charcoal glass pill.
    Top half is slightly lighter to create a subtle inner-glow sheen.
    Bottom half is deeper black for depth.
    Thin white border gives the frosted-glass edge.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Subtle dark drop-shadow for depth -->
    <item
        android:top="3dp"
        android:left="2dp"
        android:right="2dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#33000000" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <!-- Main body: dark gradient — lighter charcoal top → near-black bottom -->
    <item android:bottom="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#2A2A2E"
                android:centerColor="#1C1C22"
                android:endColor="#111116" />
            <corners android:radius="24dp" />
            <stroke android:width="1dp" android:color="#22FFFFFF" />
        </shape>
    </item>

</layer-list>
