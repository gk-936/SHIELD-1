<?xml version="1.0" encoding="utf-8"?>
<!-- Circular glassmorphic button for nav ImageButtons -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Outer shadow -->
    <item
        android:left="2dp"
        android:top="2dp"
        android:right="0dp"
        android:bottom="0dp">
        <shape android:shape="oval">
            <solid android:color="#33000000" />
        </shape>
    </item>

    <!-- Frosted glass body — radial gradient bright-centre → dark-edge -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="80%p"
                android:startColor="#2EFFFFFF"
                android:endColor="#0AFFFFFF" />
            <stroke android:width="1dp" android:color="#28FFFFFF" />
        </shape>
    </item>

</layer-list>
