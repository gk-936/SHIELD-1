<?xml version="1.0" encoding="utf-8"?>
<inset xmlns:android="http://schemas.android.com/apk/res/android"
    android:insetBottom="6dp"
    android:insetTop="6dp"
    android:insetLeft="6dp"
    android:insetRight="6dp">

    <selector>
        <!-- INTERACTION: Pressed State (Inset shadow - 'pushed into screen') -->
        <item android:state_pressed="true">
            <layer-list>
                <!-- Dark base for hole -->
                <item>
                    <shape android:shape="rectangle">
                        <corners android:radius="16dp"/>
                        <solid android:color="#111111" />
                        <!-- Edge definition -->
                        <stroke android:width="1dp" android:color="#08FFFFFF" />
                    </shape>
                </item>
                <!-- Inner top-left dark shadow (Directional gradient) -->
                <item android:bottom="4dp" android:right="4dp">
                    <shape android:shape="rectangle">
                        <corners android:radius="16dp"/>
                        <gradient
                            android:angle="135"
                            android:startColor="#99000000"
                            android:endColor="#00000000" />
                    </shape>
                </item>
            </layer-list>
        </item>

        <!-- DEFAULT STATE: Extruded 3D Pop-out -->
        <item>
            <layer-list>
                <!-- 1. Bottom-Right Shadow (High-blur, medium-opacity dark source simulation) -->
                <!-- Outer soft edge -->
                <item android:top="8dp" android:left="8dp">
                    <shape android:shape="rectangle">
                        <corners android:radius="16dp"/>
                        <solid android:color="#22000000"/>
                    </shape>
                </item>
                <!-- Core shadow -->
                <item android:top="4dp" android:left="4dp">
                    <shape android:shape="rectangle">
                        <corners android:radius="16dp"/>
                        <solid android:color="#66000000"/>
                    </shape>
                </item>

                <!-- 2. Top-Left Shadow (High-blur, low-opacity light source simulation) -->
                <!-- Outer soft highlight -->
                <item android:bottom="6dp" android:right="6dp">
                    <shape android:shape="rectangle">
                        <corners android:radius="16dp"/>
                        <solid android:color="#03FFFFFF"/>
                    </shape>
                </item>
                <!-- Core highlight -->
                <item android:bottom="3dp" android:right="3dp">
                    <shape android:shape="rectangle">
                        <corners android:radius="16dp"/>
                        <solid android:color="#08FFFFFF"/>
                    </shape>
                </item>

                <!-- 3. Surface Gradient: Convex subtle surface (Top-left to bottom-right) -->
                <item android:top="2dp" android:bottom="2dp" android:left="2dp" android:right="2dp">
                    <shape android:shape="rectangle">
                        <corners android:radius="16dp"/>
                        <gradient
                            android:angle="315"
                            android:startColor="#262626"
                            android:endColor="#141414" />
                        <!-- Border: 0.5px (1dp in Android) rgba(255,255,255, 0.05) -->
                        <stroke android:width="1dp" android:color="#0DFFFFFF"/>
                    </shape>
                </item>
            </layer-list>
        </item>
    </selector>
</inset>
