<?xml version="1.0" encoding="utf-8"?>
<!--
  bg_button_get_started.xml
  Premium "Get Started" CTA button for the User Guide last screen.
  3-layer design:
    Layer 1 — wide outer glow (cyan, 40% alpha)
    Layer 2 — thin bright border ring (cyan, 70% alpha)
    Layer 3 — main body: diagonal gradient cyan → deep violet
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Layer 1: Outer ambient glow (spreads ~6dp) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#6600C8FF" />
            <corners android:radius="32dp" />
        </shape>
    </item>

    <!-- Layer 2: Bright border ring (1dp inset from glow) -->
    <item
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#CC00C8FF" />
            <corners android:radius="28dp" />
        </shape>
    </item>

    <!-- Layer 3: Main button body — cyan #00C8FF → deep violet #4B2D9F -->
    <item
        android:left="5dp"
        android:top="5dp"
        android:right="5dp"
        android:bottom="5dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#00C8FF"
                android:centerColor="#3A7FD5"
                android:endColor="#4B2D9F" />
            <corners android:radius="26dp" />
        </shape>
    </item>

</layer-list>
