<?xml version="1.0" encoding="utf-8"?>
<!--
  bg_guide_gradient.xml
  Warm peach-purple gradient for the bottom 45% of each guide screen.
  Colors flow: deep purple → rich purple → warm orange-pink.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="linear"
        android:angle="270"
        android:startColor="#1A0A2E"
        android:centerColor="#8B2252"
        android:endColor="#FFB347"/>
</shape>
