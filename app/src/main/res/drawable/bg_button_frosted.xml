<?xml version="1.0" encoding="utf-8"?>
<!--
  Frosted dark-glass pill button background.

  Fill:   #BE1C1C1E = argb(190, 28, 28, 30) — 74.5% opaque dark
  Border: #14FFFFFF = argb(20,  255,255,255) — 8% white edge highlight
  Ripple: #26FFFFFF = argb(38,  255,255,255) — 15% white press ripple

  Use on plain AppCompat Button with:
    android:background="@drawable/bg_button_frosted"
    app:backgroundTint="@null"        ← neutralise Material tint pipeline
    android:stateListAnimator="@null" ← remove default elevation animator
    android:elevation="0dp"
-->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#26FFFFFF">

    <!-- Ripple mask: pill-shaped clipping region -->
    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
            <corners android:radius="50dp"/>
            <solid android:color="#FFFFFFFF"/>
        </shape>
    </item>

    <!-- Visible background: dark fill + white border stacked -->
    <item>
        <layer-list>
            <!-- Layer 1: Dark semi-transparent fill -->
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="50dp"/>
                    <solid android:color="#BE1C1C1E"/>
                </shape>
            </item>
            <!-- Layer 2: Subtle white border (glass edge highlight) -->
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="50dp"/>
                    <stroke android:width="1dp" android:color="#14FFFFFF"/>
                    <solid android:color="#00000000"/>
                </shape>
            </item>
        </layer-list>
    </item>

</ripple>
