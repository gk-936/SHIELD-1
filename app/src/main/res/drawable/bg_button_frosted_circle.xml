<?xml version="1.0" encoding="utf-8"?>
<!--
  Frosted dark-glass CIRCLE button background (icon-only buttons).
  Same colours as bg_button_frosted.xml but uses oval shape.
  Set layout_width and layout_height to equal values (e.g. 52dp × 52dp).
-->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#26FFFFFF">

    <!-- Ripple mask: perfect circle clipping region -->
    <item android:id="@android:id/mask">
        <shape android:shape="oval">
            <solid android:color="#FFFFFFFF"/>
        </shape>
    </item>

    <!-- Visible background -->
    <item>
        <layer-list>
            <!-- Layer 1: Dark semi-transparent fill -->
            <item>
                <shape android:shape="oval">
                    <solid android:color="#BE1C1C1E"/>
                </shape>
            </item>
            <!-- Layer 2: Subtle white border -->
            <item>
                <shape android:shape="oval">
                    <stroke android:width="1dp" android:color="#14FFFFFF"/>
                    <solid android:color="#00000000"/>
                </shape>
            </item>
        </layer-list>
    </item>

</ripple>
