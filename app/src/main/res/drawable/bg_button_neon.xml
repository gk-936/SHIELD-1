<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android" android:color="#4000F3FF">
    <item>
        <!-- Glassmorphism base with Neon Glow edge -->
        <shape android:shape="rectangle">
            <!-- Semi-rounded corners -->
            <corners android:radius="24dp" />
            
            <!-- Glassy translucent base -->
            <solid android:color="#20000000" />
            
            <!-- Neon glow stroke / Inner edge feel -->
            <stroke android:width="1.5dp" android:color="#00F3FF" />
            
            <!-- Touch target padding to ensure height >= 56dp -->
            <padding 
                android:left="24dp" 
                android:top="16dp" 
                android:right="24dp" 
                android:bottom="16dp" />
        </shape>
    </item>
</ripple>
