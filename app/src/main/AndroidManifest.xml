<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissions for Mode B functionality -->
    <!-- READ/WRITE_EXTERNAL_STORAGE are only declared for Android ≤ 10 (API 29).
         From Android 11 (API 30) onward, MANAGE_EXTERNAL_STORAGE replaces them
         entirely via the "All Files Access" special-permission page.
         Capping both at maxSdkVersion="29" keeps them out of the permissions list
         on Android 11+ where they can never be granted normally and would show ❌. -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- BIND_VPN_SERVICE is NOT a uses-permission — it is a guard declared on the
         NetworkGuardService element below so only the OS can bind it. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.KILL_BACKGROUND_PROCESSES" />
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />

    <!-- StrongBox Keystore: optional hardware security module for TEE-anchored integrity keys -->
    <uses-feature
        android:name="android.hardware.strongbox"
        android:required="false" />

    <application
        android:name=".ShieldApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SHIELD"
        android:requestLegacyExternalStorage="true">
        
        <!-- WelcomeActivity is the true launcher — shown only on first install.
             It immediately forwards to SplashActivity on subsequent launches.
             hardwareAccelerated=true is required for canvas.saveLayer() +
             PorterDuff.Mode.SCREEN to composite blobs correctly. -->
        <activity
            android:name=".WelcomeActivity"
            android:exported="true"
            android:hardwareAccelerated="true"
            android:theme="@style/Theme.SHIELD">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- SplashActivity: no longer the launcher, but still declared for
             direct navigation from WelcomeActivity and on subsequent launches. -->
        <activity
            android:name=".SplashActivity"
            android:exported="false"/>

        <activity
            android:name=".MainActivity"
            android:launchMode="singleTop"
            android:exported="false">
        </activity>

        <!-- Mode Confirmation Screen — breathing orb animation before protection starts -->
        <activity
            android:name=".ModeConfirmActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:hardwareAccelerated="true"
            android:theme="@style/Theme.SHIELD.Translucent" />

        <!-- Log Viewer Activity -->
        <activity
            android:name=".LogViewerActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:label="Event Logs" />

        <!-- SHIELD Protection Service -->
        <service
            android:name=".services.ShieldProtectionService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="ransomware_detection" />
        </service>

        <!-- Mode-A eBPF Telemetry Service (API 30+, root required) -->
        <service
            android:name=".modea.ModeAService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="ebpf_telemetry" />
        </service>

        <!-- Shield Watchdog Service -->
        <service
            android:name=".services.ShieldWatchdogService"
            android:enabled="true"
            android:exported="false"
            android:process=":watchdog" />

        <!-- Network Guard VPN Service -->
        <service
            android:name=".services.NetworkGuardService"
            android:enabled="true"
            android:exported="false"
            android:permission="android.permission.BIND_VPN_SERVICE">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
        </service>

        <!-- File Access Activity -->
        <activity
            android:name=".FileAccessActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:label="File Monitoring" />

        <!-- Recovery Activity (Snapshot) -->
        <activity
            android:name=".snapshot.RecoveryActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:label="Snapshot Recovery" />

        <!-- Emergency Recovery Activity (Locker Shield) -->
        <!-- showWhenLocked / turnScreenOn: API 27+ declarative equivalents of the -->
        <!-- FLAG_SHOW_WHEN_LOCKED and FLAG_TURN_SCREEN_ON window flags. Both the  -->
        <!-- manifest attributes and the runtime flag calls are set so the activity -->
        <!-- pierces the lockscreen across the full API 24+ range.                 -->
        <activity
            android:name=".lockerguard.EmergencyRecoveryActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:label="Emergency Recovery" />

        <!-- Locker Shield Service -->
        <service
            android:name=".lockerguard.LockerShieldService"
            android:enabled="true"
            android:exported="false"
            android:label="SHIELD Locker Guard"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/locker_shield_config" />
        </service>

        <!-- Boot Receiver -->
        <receiver
            android:name=".receivers.BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Service Restart Receiver -->
        <receiver
            android:name=".receivers.ServiceRestartReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="com.dearmoon.shield.RESTART_SERVICE" />
            </intent-filter>
        </receiver>

        <!-- Network Block Receiver -->
        <receiver
            android:name=".receivers.NetworkBlockReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="com.dearmoon.shield.BLOCK_NETWORK" />
            </intent-filter>
        </receiver>

        <!-- Test Activity -->
        <activity
            android:name=".testing.TestActivity"
            android:exported="true"
            android:parentActivityName=".MainActivity"
            android:label="Ransomware Test Suite" />

        <!-- Demo Mode Activity -->
        <activity
            android:name=".DemoActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:label="Live Demo" />

        <!-- Root Mode Info Activity -->
        <activity
            android:name=".RootModeInfoActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:label="Root Mode" />

        <!-- Settings Activity -->
        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:label="Settings" />

        <!-- User Guide Activity -->
        <activity
            android:name=".UserGuideActivity"
            android:exported="false"
            android:theme="@style/Theme.AppCompat.NoActionBar"
            android:label="Help &amp; Guide" />

        <!-- Whitelist Management Activity -->
        <activity
            android:name=".WhitelistActivity"
            android:exported="false"
            android:parentActivityName=".SettingsActivity"
            android:label="Trusted Apps" />

        <!-- Incident Report Activity (Attack Timeline + DNA Report) -->
        <activity
            android:name=".IncidentActivity"
            android:exported="false"
            android:theme="@style/Theme.AppCompat.NoActionBar" />

        <!-- Features Showcase Activity -->
        <activity
            android:name=".features.FeaturesActivity"
            android:exported="false"
            android:hardwareAccelerated="true"
            android:parentActivityName=".SettingsActivity"
            android:label="New Features" />

        <!-- FileProvider for sharing PDF and CERT-In text exports -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths" />
        </provider>

    </application>

</manifest>